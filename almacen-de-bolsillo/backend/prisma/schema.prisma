generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                  Int                   @id @default(autoincrement()) @map("id_product_p")
  sku                 String?               @unique @map("sku_p")
  shortname           String                @map("shortname_p")
  longname            String                @map("longname_p")
  description         String?               @map("description_p")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  price               Decimal               @map("price_p") @db.Decimal(10, 2)
  stock               Int                   @default(0) @map("stock_p")
  stockMin            Int                   @default(0) @map("stock_min_p")
  discount            Decimal               @default(0) @map("discount_p") @db.Decimal(10, 2)
  categoryId          Int                   @map("id_category_p")
  status              Boolean               @default(true) @map("status_p")
  category            Category              @relation(fields: [categoryId], references: [id])
  purchaseOrdersItems PurchaseOrdersItems[]
  saleOrdersItems     SalesOrdersItems[]
  stockMovements      StockMovements[]
  isActive            Boolean               @default(true) @map("is_active_p")

  @@map("products_p")
}

model Category {
  id          Int       @id @default(autoincrement()) @map("id_category_c")
  name        String    @map("name_c")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  description String?   @map("description_c")
  products    Product[]
  isActive    Boolean   @default(true) @map("is_active_c")

  @@map("categories_c")
}

model Supplier {
  id             Int             @id @default(autoincrement()) @map("id_supplier_s")
  name           String          @map("name_s")
  cuit           String?         @unique @map("cuit_s")
  phone          String?         @map("phone_s")
  email          String?         @map("email_s")
  address        String?         @map("address_s")
  status         Boolean         @default(true) @map("status_s")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  isActive       Boolean         @default(true) @map("is_active_s")
  purchaseOrders PurchaseOrder[]

  @@map("suppliers_s")
}

model PurchaseOrder {
  id                  Int                   @id @unique @default(autoincrement()) @map("id_purchase_orders_po")
  date                DateTime              @default(now()) @map("date_po")
  total               Decimal               @default(0) @map("total_po") @db.Decimal(10, 2)
  supplierId          Int                   @map("id_supplier_po")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  purchaseOrdersItems PurchaseOrdersItems[]
  userId              Int                   @default(3) @map("id_user_po")
  isActive            Boolean               @default(true) @map("is_active_po")

  supplier Supplier @relation(fields: [supplierId], references: [id])
  buyer    User     @relation(fields: [userId], references: [id])

  @@map("purchase_orders_po")
}

model PurchaseOrdersItems {
  productId       Int           @map("id_product_poi")
  purchaseOrderId Int           @map("id_purchase_order_poi")
  quantity        Int           @default(0) @map("quantity_poi")
  price           Decimal       @default(0) @map("price_poi") @db.Decimal(10, 2)
  discount        Decimal       @default(0) @map("discount_poi") @db.Decimal(10, 2)
  subtotal        Decimal       @default(0) @map("subtotal_poi") @db.Decimal(10, 2)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@id([productId, purchaseOrderId])
  @@map("purchase_orders_items_poi")
}

model Transaction {
  id            Int           @id @default(autoincrement()) @map("id_transaction_t")
  date          DateTime      @default(now()) @map("date_t")
  amount        Decimal       @map("amount_t") @db.Decimal(10, 2)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  paymentMethod PaymentMethod @default(EFECTIVO) @map("payment_method_t")

  @@map("transactions_t")
}

model Balance {
  id              Int      @id @default(autoincrement()) @map("id_balance_b")
  date            DateTime @default(now()) @map("date_b")
  cashIn          Decimal  @map("cash_in_b") @db.Decimal(10, 2)
  cashOut         Decimal  @map("cash_out_b") @db.Decimal(10, 2)
  expectedClosing Decimal  @map("expected_closing_b")
  actualClosing   Decimal  @map("actual_closing_b")
  difference      Decimal  @map("difference_b")
  createdAt       DateTime @default(now()) @map("created_at")
  opening         Decimal  @map("opening_b") @db.Decimal(10, 2)
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("balance_b")
}

model User {
  id             Int             @id @default(autoincrement()) @map("id_user_u")
  username       String          @unique @map("username_u")
  email          String          @unique @map("email_u")
  last_access    DateTime        @map("last_access_u")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  isActive       Boolean         @default(true) @map("is_active_u")
  passwordHash   String          @map("password_hash_u")
  role           Role            @default(EMPLOYEE) @map("role_u")
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]

  @@map("users_u")
}

model SalesOrder {
  id              Int                @id @default(autoincrement()) @map("id_sales_orders_so")
  invoice         String?            @map("invoice_so")
  date            DateTime           @default(now()) @map("date_so")
  sellerId        Int                @default(3) @map("id_user_so")
  createdAt       DateTime           @default(now()) @map("created_at")
  discount        Decimal            @default(0) @map("discount_so") @db.Decimal(10, 2)
  iva             Decimal            @default(0) @map("iva_so") @db.Decimal(10, 2)
  isActive        Boolean            @default(true) @map("is_active_so")
  total           Decimal            @default(0) @map("total_so") @db.Decimal(10, 2)
  updatedAt       DateTime           @updatedAt @map("updated_at")
  paymentMethod   PaymentMethod      @default(EFECTIVO) @map("payment_method_so")
  salesOrdersItem SalesOrdersItems[]
  seller          User               @relation(fields: [sellerId], references: [id])

  @@map("sales_orders_so")
}

model SalesOrdersItems {
  salesOrdersItemId Int        @map("id_sales_order_soi")
  productId         Int        @map("id_product_soi")
  quantity          Int        @default(0) @map("quantity_soi")
  shortname         String     @map("shortname_soi")
  longname          String?    @map("longname_soi")
  price             Decimal    @default(0) @map("price_soi") @db.Decimal(10, 2)
  subtotal          Decimal    @default(0) @map("subtotal_soi") @db.Decimal(10, 2)
  discount          Decimal    @default(0) @map("discount_soi") @db.Decimal(10, 2)
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  product           Product    @relation(fields: [productId], references: [id])
  salesOrder        SalesOrder @relation(fields: [salesOrdersItemId], references: [id])

  @@id([salesOrdersItemId, productId])
  @@map("sales_orders_items_soi")
}

model Employee {
  id        Int       @id @default(autoincrement()) @map("id_employee_e")
  firstname String?   @map("firstname_e")
  lastname  String?   @map("lastname_e")
  fullname  String?   @map("fullname_e")
  dni       String?   @map("dni_e")
  cuil      String?   @map("cuil_e")
  dob       DateTime? @map("dob_e")
  salary    Decimal?  @map("salary_e") @db.Decimal(10, 2)
  jobTitle  String?   @map("job_title_e")
  pto       String?   @map("pto_e")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isActive  Boolean   @default(true) @map("is_active_e")
  gender    Gender    @default(M) @map("gender_e")

  @@map("employees_e")
}

model StockMovements {
  id            Int               @id @default(autoincrement()) @map("id_stockmovement_sm")
  type          StockMovementType @map("type_sm")
  productId     Int               @map("product_id_sm")
  quantity      Int               @map("quantity_sm")
  previousStock Int               @map("previous_stock_sm")
  newStock      Int               @map("new_stock_sm")
  reason        String            @map("reason_sm")
  createdAt     DateTime          @default(now()) @map("created_at_sm")
  product       Product           @relation(fields: [productId], references: [id])

  @@map("stock_movements_sm")
}

enum StockMovementType {
  PURCHASE
  SALE
  MANUAL_ENTRY
  MANUAL_EXIT
  ADJUSTMENT
}

enum PaymentMethod {
  EFECTIVO
  MERCADOPAGO
  UALA
}

enum Role {
  ADMIN
  BUSINESS_OWNER
  SUPERVISOR
  EMPLOYEE
}

enum Gender {
  M
  F
  OTHER
}
